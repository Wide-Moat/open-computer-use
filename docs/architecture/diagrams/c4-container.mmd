%% Canonical Layer 6 (C4 Container) diagram. Referenced from docs/architecture/05-c4-container.md.
%% Role names only — no technology names (per CLAUDE.md Diagrams). Tech choice lands in component specs under components/.
%% Containers across the Layer-3 trust zones: the Control plane splits into an agent-facing MCP gateway
%% and an operator/lifecycle API (the kill-switch lives only on the latter); storage is one door — the
%% Object-store service — fronted by the Web UI (host leg) and the in-guest mount client (guest leg), ADR-0015.
%% The count is a then-true observation, not an invariant (05-c4-container.md §1). Substrate differs by shelf (§5).
%% Palette (project convention): red untrusted / green trusted. Amber/blue trust-zone shading is Layer 3 only.

%%{init: {"theme": "neutral"} }%%
flowchart LR

    %% ─── external (drawn for orientation; contracts in 03-c4-context.md §4) ───
    PEER["MCP-speaking caller<br/>(runs the loop)"]:::ext
    OPER["Operator<br/>(PAM-JIT human)"]:::ext
    FILE["Data-plane client<br/>(OCU SPA · Web UI file API)"]:::extOpt
    UPSTREAM["Outbound endpoints<br/>(LLM · internal API)"]:::ext
    ENGINE["Storage engine<br/>(S3 or local volume · off-box<br/>verifies the injected real credential · enforces filesystem_id scope)"]:::ext
    SINK["Customer SIEM / SOAR /<br/>transparency log"]:::extOpt
    SDS["SDS source<br/>(static file solo · customer store enterprise)"]:::extOpt
    ISSUER["RFC 8693 exchange counterparty<br/>(issues the real filestore credential at the edge; may be external)<br/>the Control plane mints the weak Storage-JWT + holds its signing key + publishes the JWKS the edge validates against"]:::extOpt

    %% ─── containers inside the system under design ───
    subgraph OCU["Open Computer Use"]
        MCPG["MCP gateway<br/>agent-facing tool-calls · metadata-only"]
        CTRL["Control / operator API<br/>lifecycle · quota · kill-switch · credential DELIVERY"]
        OSS["Object-store service<br/>the only door to storage · speaks the engine protocol<br/>receives the edge-injected real credential · no signing key"]
        WEBUI["Web UI<br/>file upload / preview / download · SPA · parser-sandbox<br/>OUR design · no signing key"]
        VM["Session sandbox [1..N]<br/>guest agent = PID 1 · in-guest mount client (dials the object-store service guest-out)"]
        EDGE["Egress trust-edge proxy<br/>single TLS-inspected hop · validates the weak session JWT · exchanges it at the issuer for the real filestore credential<br/>no storage signing key · exchanges, does not mint the filestore credential · (data plane + SDS leaf-minter for the TLS bump)"]
        AUD["Audit pipeline<br/>durable bus · hash-chained store"]
    end

    %% ─── inbound (two distinct surfaces of the Control plane; the Web UI fronts E5) ───
    PEER -->|"F1: MCP authz spec"| MCPG
    OPER -->|"F2: PAM-JIT credential · operator-only ingress"| CTRL
    MCPG -->|"F5: session create / status<br/>service identity"| CTRL
    FILE -.->|"F11: SPA · file API (upload/preview/download)<br/>embed token → first-party session · bytes direct"| WEBUI

    %% ─── control + provisioning reach the guest host-side (host dials, guest listens; NFR-SEC-43) ───
    CTRL -->|"F6: Session JWT · checked against a separately-supplied expected container name (not a JWT claim)<br/>host-attested caller · host dials guest"| VM
    CTRL -->|"F7: mount provisioning push (ProvisionMountConfig)<br/>Control-plane-minted+signed scoped Storage-JWT + ca_cert · host dials guest"| VM

    %% ─── ONE door to storage: both legs reach the Object-store service, and only it speaks to the
    %%     storage engine. Guest leg: in-guest mount client → egress → object-store service → engine.
    %%     Host leg: Web UI → object-store service → engine (F9; does NOT cross the egress hop). ───
    VM -->|"F8: single outbound · guest dials out"| EDGE
    VM -.->|"F7a: storage data leg over F8<br/>service_url · weak session JWT presented as Bearer"| EDGE
    SDS -->|"upstream credential over SDS<br/>source owns mint/rotate/revoke (hardening rung)"| EDGE
    WEBUI -->|"F9: file-op intent (host leg)<br/>intra-deployment · does not cross egress"| OSS
    EDGE -->|"agent egress · forwards to origin"| UPSTREAM
    EDGE -.->|"RFC 8693 exchange: presents the validated weak session JWT<br/>receives the real filestore credential (per-session, cached)"| ISSUER
    EDGE -->|"storage data leg (guest) · validates the weak session JWT<br/>injects the exchanged real filestore credential"| OSS
    OSS -->|"the only door · engine verifies the injected real credential · enforces filesystem_id scope (ADR-0019)"| ENGINE

    %% ─── audit fan-in (host-side containers only; the Session sandbox does NOT emit) ───
    %% A compromised guest can neither reach nor silence the pipeline; host-side
    %% containers author the guest's audit events.
    MCPG -->|OCSF| AUD
    CTRL -->|OCSF| AUD
    OSS -->|OCSF| AUD
    WEBUI -->|OCSF| AUD
    EDGE -->|OCSF| AUD
    AUD -.->|"OCSF bridge<br/>full shelf"| SINK

    %% ─── styling (project palette) ───
    classDef ext fill:#fdecea,stroke:#c0392b,stroke-width:1px;
    classDef extOpt fill:#fdecea,stroke:#c0392b,stroke-dasharray: 5 5;
    style OCU fill:#e8f5e9,stroke:#1e7e34,stroke-width:3px;
