%% Layer 7 STRIDE overlay on the Layer 6 container DFD. Referenced from docs/architecture/06-threat-model.md.
%% Residual (PARTIAL) threats annotated per element; the DFD itself is canonical in c4-container.mmd (not redrawn).
%%{init: {"theme": "neutral"} }%%
flowchart LR
    PEER["MCP caller"]:::ext
    OPER["Operator"]:::ext
    DPC["Data-plane client<br/>(SPA / headless)"]:::ext
    SDS["SDS source<br/>(static file / customer store)"]:::ext
    ENGINE["Storage engine<br/>(off-box · verifies the injected real credential · enforces scope)"]:::ext
    subgraph OCU["Open Computer Use — STRIDE overlay"]
        MCPG["MCP gateway"]
        CTRL["Control / operator API"]
        OSS["Object-store service (P4-mount door)<br/>the only door to storage"]
        WEBUI["Web UI (P4-artifact)<br/>file API · SPA · parser-sandbox"]
        VM["Session sandbox [1..N]<br/>+ in-guest mount client"]
        EDGE["Egress trust-edge proxy"]
        AUD["Audit pipeline"]
    end
    PEER --> MCPG
    OPER --> CTRL
    MCPG --> CTRL
    CTRL -->|"F6 exec/control + F7 provisioning push"| VM
    DPC -->|"F11"| WEBUI
    WEBUI -->|"F9 file-op (host leg)"| OSS
    VM -->|"F7a guest mount data leg"| EDGE
    VM -->|"F8 egress"| EDGE
    EDGE -->|"storage data leg (guest)"| OSS
    OSS -->|"the only door"| ENGINE
    SDS -.->|"upstream credential over SDS (hardening rung)"| EDGE
    %% The Session sandbox does NOT emit to audit (dead model #3). Host-side
    %% components author the guest's audit events; fan-in is host-side only.
    EDGE -.OCSF.-> AUD
    OSS -.OCSF.-> AUD
    WEBUI -.OCSF.-> AUD
    MCPG -.OCSF.-> AUD
    CTRL -.OCSF.-> AUD

    PEND["NFR specified, impl tracked<br/>#148 #149 #150 #176 #181 #182 #183<br/>#184 #185 #186 #187 #188 #197 #198<br/>#217 #218"]:::pend
    MCPG -. P1-I1 P1-E2 .-> PEND
    CTRL -. P2-R1 P7-R3 .-> PEND
    OSS -. "P4-mount-D1 P4-mount-D2 P4-mount-E1 P4-mount-E2 P4-mount-S2 P4-mount-I1" .-> PEND
    WEBUI -. "P4-artifact-S3 P4-artifact-T3 P4-artifact-I3 P4-artifact-D3 P4-artifact-R2 P4-artifact-E3" .-> PEND
    VM -. P5-T1 P5-I1 P5-I2 P5-I3 P5-I4 P5-R1 .-> PEND
    EDGE -. P6-I1 P6-D1 P6-D3 P6-E1 P6-T1 P6-I3 .-> PEND
    AUD -. P7-T2 P7-T3 .-> PEND

