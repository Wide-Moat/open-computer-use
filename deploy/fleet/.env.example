# Fleet bring-up environment. Copy to `.env` (gitignored) and set real values.
# The two embed/session secrets are fail-closed: compose refuses to start
# without them (no default), because a default-keyed deployment would verify
# any forged embed token. Generate each with `openssl rand -hex 32`.

# Web UI BFF — required, >=32 bytes each. No default by design.
OCU_EMBED_VERIFY_SECRET=
OCU_SESSION_SECRET=

# Web UI BFF — optional, shown with their compose defaults.
OCU_EMBED_AUDIENCE=ocu-webui

# Object-store + MinIO — optional, shown with their compose defaults.
OCU_S3_ACCESS_KEY_ID=ocu-fleet-root
OCU_S3_SECRET_ACCESS_KEY=ocu-fleet-secret-key
OCU_S3_BUCKET=ocu-fleet
OCU_FILESYSTEM_ID=fs-fleet
